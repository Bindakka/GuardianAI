# GuardianAI — Environment Variables
# Copy this to .env, fill in your values, NEVER commit .env to GitHub

# Google Gemini API Key (FREE)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AQ.Ab8RN6LQ6WwnTI3p0DcvaH5EqXm7T-yF_53LwlZQq5tvbJHTIg

# MongoDB Atlas URI (FREE tier available)
# Get from: https://www.mongodb.com/atlas → Connect → Drivers → Python
MONGODB_URI=mongodb+srv://guardianai:Guardian12345@cluster0.3ku4q.mongodb.net/?appName=Cluster0
# Database name (no need to change)
DB_NAME=guardianai

# Port (Cloud Run sets this automatically)
PORT=8080
